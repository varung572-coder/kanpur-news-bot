15\u0930 \u0932\u094b\u0917\u094b\u0902 \u092e\u0947\u0902 \u0917\u0941\u0938\u094d\u0938\u093e - Zee News", "UP \u092e\u0947\u0902 \u0906\u091f\u094b \u092e\u0947\u0902 '\u0909\u0932\u094d\u091f\u0940 \u0917\u0948\u0902\u0917'! \u0915\u093e\u0928\u092a\u0941\u0930 \u092e\u0947\u0902 \u091a\u0902\u0926\u094c\u0932\u0940 \u0915\u093e \u0936\u093e\u0924\u093f\u0930 \u0917\u0948\u0902\u0917 Encounter \u0915\u0947 \u092c\u093e\u0926 \u092a\u0915\u0921\u093c\u093e, \u092a\u0932\u0915 \u091d\u092a\u0915\u0924\u0947 \u0938\u0935\u093e\u0930\u0940 \u0915\u093e \u092a\u0930\u094d\u0938, \u091c\u0947\u0935\u0930 \u0917\u093e\u092f\u092c - kanpur police busts vomit gang 5 arrested including 3 women after encounter - Jagran", "\u0915\u093e\u0928\u092a\u0941\u0930 \u092e\u0947\u0902 \u0905\u0902\u092c\u0947\u0921\u0915\u0930 \u091c\u092f\u0902\u0924\u0940 \u092a\u0930 \u0917\u094b\u0937\u094d\u0920\u0940: \u0938\u0924\u0940\u0936 \u092e\u0939\u093e\u0928\u093e \u0928\u0947 \u0926\u093f\u092f\u093e \u0938\u092e\u093e\u0928\u0924\u093e \u0915\u093e \u0938\u0902\u0926\u0947\u0936, \u0915\u0939\u093e- \u0938\u0902\u0935\u093f\u0927\u093e\u0928 \u0926\u0947\u0936 \u0915\u0940 \u0906\u0924\u094d\u092e\u093e - Dainik Bhaskar", "\u0939\u0948\u0932\u091f \u0938\u0947 \u092d\u093e\u0917\u0947 \u0932\u0941\u091f\u0947\u0930\u0947 \u0915\u094b \u092e\u0941\u0916\u092c\u093f\u0930 \u0926\u094b\u0938\u094d\u0924 \u0928\u0947 \u0915\u0930\u093e\u092f\u093e \u0905\u0930\u0947\u0938\u094d\u091f: \u0932\u095c\u0916\u095c\u093e\u0924\u0947 \u0939\u0941\u090f \u092a\u0939\u0941\u0902\u091a\u093e \u0917\u094d\u0935\u093e\u0932\u091f\u094b\u0932\u0940, \u092c\u094b\u0932\u093e \u0915\u093f- \u092e\u0941\u091d\u0947 \u092c\u091a\u093e \u0932\u094b... ... - Dainik Bhaskar", "\u0915\u093e\u0928\u092a\u0941\u0930 \u092e\u0947\u0902 \u0930\u093f\u091f\u093e\u092f\u0930 \u0926\u0930\u094b\u0917\u093e \u0915\u0947 \u092c\u0947\u091f\u0947 \u0915\u0940 \u0926\u092c\u0902\u0917\u0908, \u092e\u094b\u092c\u093e\u0907\u0932 \u091a\u094b\u0930\u0940 \u0915\u0947 \u0906\u0930\u094b\u092a \u092e\u0947\u0902 \u0926\u0941\u0915\u093e\u0928\u0926\u093e\u0930 \u0915\u094b \u092c\u0947\u0930\u0939\u092e\u0940 \u0938\u0947 \u092a\u0940\u091f\u093e, \u092e\u094c\u0924 - Jagran", "Kanpur News: \u092b\u094d\u0932\u0948\u091f\u0947\u0921 \u092b\u0948\u0915\u094d\u091f\u0940 \u092e\u0947\u0902 144 \u0907\u0915\u093e\u0907\u092f\u094b\u0902 \u0915\u093e \u0906\u0935\u0902\u091f\u0928, \u0932\u0917\u0928\u0947 \u0932\u0917\u0940\u0902 \u092e\u0936\u0940\u0928\u0947\u0902 - Amar Ujala", "Kanpur Twin Murder:'\u092a\u0924\u093f \u0938\u0947 \u0932\u0917\u0924\u093e \u0925\u093e \u0921\u0930... \u092a\u0924\u094d\u0928\u0940 \u0928\u0947 \u0928\u093f\u0917\u0930\u093e\u0928\u0940 \u0915\u0947 \u0932\u093f\u090f \u0932\u0917\u0935\u093e\u090f \u0925\u0947 6 \u0915\u0948\u092e\u0930\u0947, \u0915\u093e\u0924\u093f\u0932 \u092a\u0924\u093f \u0928\u0947 \u0935\u093e\u0930\u0926\u093e\u0924 \u0938\u0947 \u092a\u0939\u0932\u0947 \u0910\u0938\u0947 \u0926\u093f\u092f\u093e \u091a\u0915\u092e\u093e - kanpur twin murder father turned cctv cameras before brutal killing daughters in kidwai nagar - Jagran", "Kanpur Mandi Bhav: \u0938\u094b\u0928\u093e-\u091a\u093e\u0902\u0926\u0940 \u0938\u0947 \u0932\u0947\u0915\u0930 \u0926\u093e\u0932\u094b\u0902 \u0924\u0915 \u0915\u0947 \u0928\u090f \u0930\u0947\u091f \u091c\u093e\u0930\u0940, 21 \u0905\u092a\u094d\u0930\u0948\u0932 2026 \u0915\u0947 \u092e\u0902\u0921\u0940 \u092d\u093e\u0935 \u0915\u0940 \u0932\u093f\u0938\u094d\u091f - Jagran", "Kanpur \u0915\u0947 \u0905\u0938\u094d\u092a\u0924\u093e\u0932\u094b\u0902 \u0915\u0940 \u0906\u091c 20 \u0905\u092a\u094d\u0930\u0948\u0932 \u0915\u0940 \u0913\u092a\u0940\u0921\u0940, \u0915\u094c\u0928 \u0938\u0947 \u0921\u0949\u0915\u094d\u091f\u0930 \u0909\u092a\u0932\u092c\u094d\u0927 \u0939\u0948\u0902? \u0926\u0947\u0916\u0947\u0902 \u092a\u0942\u0930\u0940 \u0938\u0942\u091a\u0940 - Jagran", "\u0938\u0942\u0930\u091c \u0915\u0940 \u0924\u0932\u094d\u0916\u0940 \u0938\u0947 \u092c\u095d\u0940 \u092c\u0947\u091a\u0948\u0928\u0940, \u092a\u094d\u0930\u091a\u0902\u0921 \u0917\u0930\u094d\u092e\u0940 \u0928\u0947 \u0915\u093f\u092f\u093e \u092c\u0947\u0939\u093e\u0932 - Hindustan Hindi News", "Kanpur News: \u0918\u0930-\u0918\u0930 \u091c\u093e\u0915\u0930 \u092e\u0924\u0926\u093e\u0924\u093e \u0938\u0942\u091a\u0940 \u0915\u093e \u0938\u0924\u094d\u092f\u093e\u092a\u0928 \u0915\u0930\u0947\u0902\u0917\u0947 \u0915\u093e\u0902\u0917\u094d\u0930\u0947\u0938\u0940 - Amar Ujala", "This Kanpur-based company is building next-generation protection systems for 3M+ soldiers across 230+ forces in 100+ countries - Startup Pedia", "IIT \u0915\u093e\u0928\u092a\u0941\u0930 \u092e\u0947\u0902 BTech \u0915\u0940 \u092b\u0940\u0938 \u0915\u093f\u0924\u0928\u0940 \u0939\u0948, \u0926\u0947\u0916\u0947\u0902 \u0938\u0947\u092e\u0947\u0938\u094d\u091f\u0930 \u0935\u093e\u0907\u091c \u0938\u094d\u091f\u094d\u0930\u0915\u094d\u091a\u0930 - Prabhat Khabar", "Kanpur News: \u0921\u0949. \u0928\u093e\u0917\u0947\u0902\u0926\u094d\u0930 \u0938\u094d\u0935\u0930\u0942\u092a \u0938\u094d\u092e\u0943\u0924\u093f \u0917\u094b\u0932\u094d\u0921 \u0915\u092a \u092e\u0947\u0902 \u0915\u093e\u0928\u092a\u0941\u0930 \u091c\u0947\u092e\u094d\u0938 \u0928\u0947 108 \u0930\u0928 \u0938\u0947 \u091c\u0940\u0924\u093e \u092e\u0948\u091a - Amar Ujala", "Kanpur kidney racket: Absconding OT technician surrenders in court, 11 arrests so far | Hindustan Times - Hindustan Times", "\u0915\u093e\u0928\u092a\u0941\u0930 \u092e\u0947\u0902 \u0924\u0940\u0928 \u092e\u0902\u091c\u093f\u0932\u093e \u092e\u0915\u093e\u0928 \u092e\u0947\u0902 \u0932\u0917\u0940 \u0906\u0917, \u0932\u092a\u091f\u094b\u0902 \u0915\u0947 \u092c\u0940\u091a \u0928\u093f\u0915\u0932\u093e \u092a\u0930\u093f\u0935\u093e\u0930 - Hindustan Hindi News", "\u0932\u0916\u0928\u090a-\u0915\u093e\u0928\u092a\u0941\u0930 \u0938\u092b\u0930 \u092a\u0921\u093c\u094