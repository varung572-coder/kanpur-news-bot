["\u0915\u093e\u0928\u092a\u0941\u0930: \u091c\u091c\u094d\u092c\u0947 \u0915\u094b \u0938\u0932\u093e\u092e! \u0930\u094b\u091c 4 \u0918\u0902\u091f\u0947 \u0905\u092d\u094d\u092f\u093e\u0938 \u0914\u0930 \u092a\u0926\u0915\u094b\u0902 \u0915\u0940 \u092c\u094c\u091b\u093e\u0930, \u091c\u093e\u0928\u0947\u0902 \u092a\u093e\u0935\u0930 \u0932\u093f\u092b\u094d\u091f\u0930 \u0938\u093f\u092f\u093e \u092f\u093e\u0926\u0935 \u0915\u093e \u0938\u092b\u0930 - Amar Ujala", "Kanpur Firm Alleges \u20b92 Crore Embezzlement by Accountant - The420.in", "Kanpur \u092e\u0947\u0902 16 \u0905\u092a\u094d\u0930\u0948\u0932 2026 \u0915\u093e \u092e\u0902\u0921\u0940 \u092d\u093e\u0935, \u0905\u0928\u093e\u091c \u0938\u0947 \u0932\u0947\u0915\u0930 \u0938\u094b\u0928\u093e-\u091a\u093e\u0902\u0926\u0940 \u0924\u0915 \u0915\u0947 \u0928\u090f \u0930\u0947\u091f \u091c\u093e\u0930\u0940 - Jagran", "Kanpur kidney racket: Absconding OT technician surrenders in court, 11 arrests so far - ThePrint", "\u0915\u093e\u0928\u092a\u0941\u0930 \u092e\u0947\u0902 \u092f\u0941\u0935\u0915 \u0915\u094b \u091a\u092a\u094d\u092a\u0932\u094b\u0902 \u0938\u0947 \u092a\u0940\u091f\u093e: \u092c\u093e\u0907\u0915 \u091f\u0915\u0930\u093e\u0928\u0947 \u092a\u0930 \u0935\u093f\u0935\u093e\u0926, \u091c\u093e\u0902\u091a \u092e\u0947\u0902 \u091c\u0941\u091f\u0940 \u092a\u0941\u0932\u093f\u0938 - Dainik Bhaskar", "\u0915\u093e\u0928\u092a\u0941\u0930 \u092e\u0947\u0902 \u092a\u0925\u0930\u093e\u0935 \u0938\u0947 \u0905\u0902\u092c\u0947\u0921\u0915\u0930 \u092a\u094d\u0930\u0924\u093f\u092e\u093e \u0915\u094d\u0937\u0924\u093f\u0917\u094d\u0930\u0938\u094d\u0924: \u0935\u093f\u0935\u093e\u0926 \u0915\u0947 \u092c\u093e\u0926 \u0917\u093e\u0902\u0935 \u092e\u0947\u0902 \u0924\u0928\u093e\u0935, \u0924\u0940\u0928 \u092f\u0941\u0935\u0915 \u092a\u0930 \u0906\u0930\u094b\u092a - Dainik Bhaskar", "Lakhimpur Kheri News: \u0932\u0916\u0940\u092e\u092a\u0941\u0930 \u0921\u093f\u092a\u094b \u0928\u0947 \u0936\u0941\u0930\u0942 \u0915\u0940 \u0915\u093e\u0928\u092a\u0941\u0930 \u0915\u0947 \u0932\u093f\u090f \u0938\u0940\u0927\u0940 \u0930\u094b\u0921\u0935\u0947\u091c \u0938\u0947\u0935\u093e - Amar Ujala", "Kanpur News: \u0915\u093e\u0928\u092a\u0941\u0930 \u092e\u0947\u0902 \u0921\u094d\u0930\u094b\u0928 \u0915\u0940 \u092e\u0926\u0926 \u0938\u0947 \u0917\u093e\u0902\u091c\u093e \u0924\u0938\u094d\u0915\u0930\u094b\u0902 \u0915\u093e \u092d\u0902\u0921\u093e\u092b\u094b\u0921\u093c, 7 \u092e\u0939\u093f\u0932\u093e\u090f\u0902 \u0917\u093f\u0930\u092b\u094d\u0924\u093e\u0930 - ABP News", "45 \u092e\u093f\u0928\u091f\u094b\u0902 \u092e\u0947\u0902 \u0939\u094b\u0917\u093e \u0926\u094b \u0936\u0939\u0930\u094b\u0902 \u0915\u093e '\u092e\u093f\u0932\u0928' \u092d\u0942\u0932 \u091c\u093e\u0907\u090f \u0915\u094d\u092f\u093e \u0939\u094b\u0924\u093e \u0939\u0948 \u091c\u093e\u092e, NHAI \u0928\u0947 \u0926\u0940 \u092c\u0921\u093c\u0940 \u0916\u0941\u0936\u0916\u092c\u0930\u0940 - Zee News", "Kanpur \u0915\u0947 \u092a\u094d\u0930\u092e\u0941\u0916 \u0905\u0938\u094d\u092a\u0924\u093e\u0932\u094b\u0902 \u092e\u0947\u0902 \u0936\u0941\u0915\u094d\u0930\u0935\u093e\u0930 \u0915\u094b \u0915\u094c-\u0915\u094c\u0928 \u0938\u0947 \u0921\u0949\u0915\u094d\u091f\u0930 \u0930\u0939\u0947\u0902\u0917\u0947 \u0909\u092a\u0932\u092c\u094d\u0927, \u092f\u0947 \u0930\u0939\u0940 \u092a\u0942\u0930\u0940 \u0932\u093f\u0938\u094d\u091f - Jagran", "Kanpur kidney racket: Absconding OT technician surrenders in court, 11 arrests so far | Hindustan Times - Hindustan Times", "\u0915\u093e\u0928\u092a\u0941\u0930: \u0915\u0941\u0924\u094d\u0924\u093e \u092a\u0915\u0921\u093c\u0928\u0947 \u0917\u0908 \u0928\u0917\u0930 \u0928\u093f\u0917\u092e \u091f\u0940\u092e \u092a\u0930 \u0939\u092e\u0932\u093e, \u091b\u0939 \u0928\u093e\u092e\u091c\u0926 \u0938\u092e\u0947\u0924 \u0915\u0908 \u0905\u091c\u094d\u091e\u093e\u0924 \u092a\u0930 \u0917\u0902\u092d\u0940\u0930 \u0927\u093e\u0930\u093e\u0913\u0902 \u092e\u0947\u0902 FIR \u0926\u0930\u094d\u091c - Amar Ujala", "\u0915\u093e\u0928\u092a\u0941\u0930 \u092e\u0947\u0902 \u092f\u092e\u0941\u0928\u093e \u0928\u0926\u0940 \u092e\u0947\u0902 \u0921\u0942\u092c\u0947 \u092f\u0941\u0935\u0915 \u0915\u093e \u0936\u0935 \u092c\u0930\u093e\u092e\u0926: \u092e\u091b\u0932\u0940 \u092a\u0915\u0921\u093c\u0928\u0947 \u0917\u092f\u093e \u0925\u093e, \u092a\u0941\u0932\u093f\u0938 \u0928\u0947 \u0936\u0935 \u092a\u094b\u0938\u094d\u091f\u092e\u0949\u0930\u094d\u091f\u092e \u0915\u094b \u092d\u0947\u091c\u093e - Dainik Bhaskar", "\u0938\u093e\u0939\u092c, \u092e\u0941\u091d\u0947 \u0907\u0902\u0938\u093e\u092b \u0926\u094b: \u092a\u0932\u094d\u0932\u0942 \u092b\u0948\u0932\u093e\u0915\u0930 \u092a\u0924\u094d\u0928\u0940 \u092e\u093e\u0902\u0917 \u0930\u0939\u0940 \u092a\u0924\u093f \u0915\u0940 \u092e\u094c\u0924 \u0915\u093e \u0928\u094d\u092f\u093e\u092f, \u0916\u093e\u0915\u0940 \u092a\u0930 \u0932\u0917\u093e\u090f \u0906\u0930\u094b\u092a - Amar Ujala"]